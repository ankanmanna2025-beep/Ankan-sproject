#include <stdio.h>

void square()
{
    int n, style;

    printf("Enter side length: ");
    scanf("%d", &n);

    printf("1. Hollow\n2. Filled\n");
    printf("Choose style: ");
    scanf("%d", &style);

    for(int i=0;i<n;i++)
    {
        for(int j=0;j<n;j++)
        {
            if(style==2 || i==0 || i==n-1 || j==0 || j==n-1)
                printf("* ");
            else
                printf("  ");
        }
        printf("\n");
    }
}

void rectangle()
{
    int w,h,style;

    printf("Enter width: ");
    scanf("%d",&w);

    printf("Enter height: ");
    scanf("%d",&h);

    printf("1. Hollow\n2. Filled\n");
    printf("Choose style: ");
    scanf("%d",&style);

    for(int i=0;i<h;i++)
    {
        for(int j=0;j<w;j++)
        {
            if(style==2 || i==0 || i==h-1 || j==0 || j==w-1)
                printf("* ");
            else
                printf("  ");
        }
        printf("\n");
    }
}

void triangle()
{
    int n,style;

    printf("Enter height: ");
    scanf("%d",&n);

    printf("1. Hollow\n2. Filled\n");
    printf("Choose style: ");
    scanf("%d",&style);

    for(int i=1;i<=n;i++)
    {
        for(int j=1;j<=i;j++)
        {
            if(style==2 || i==n || j==1 || j==i)
                printf("* ");
            else
                printf("  ");
        }
        printf("\n");
    }
}

void invertedTriangle()
{
    int n,style;

    printf("Enter height: ");
    scanf("%d",&n);

    printf("1. Hollow\n2. Filled\n");
    printf("Choose style: ");
    scanf("%d",&style);

    for(int i=n;i>=1;i--)
    {
        for(int j=1;j<=i;j++)
        {
            if(style==2 || i==n || j==1 || j==i)
                printf("* ");
            else
                printf("  ");
        }
        printf("\n");
    }
}

void diamond()
{
    int n;

    printf("Enter size: ");
    scanf("%d",&n);

    for(int i=1;i<=n;i++)
    {
        for(int j=i;j<n;j++)
            printf(" ");

        for(int j=1;j<=2*i-1;j++)
            printf("*");

        printf("\n");
    }

    for(int i=n-1;i>=1;i--)
    {
        for(int j=n;j>i;j--)
            printf(" ");

        for(int j=1;j<=2*i-1;j++)
            printf("*");

        printf("\n");
    }
}

void parallelogram()
{
    int n;

    printf("Enter size: ");
    scanf("%d",&n);

    for(int i=1;i<=n;i++)
    {
        for(int j=n;j>i;j--)
            printf(" ");

        for(int j=1;j<=n;j++)
            printf("* ");

        printf("\n");
    }
}

int main()
{
    int choice;

    while(1)
    {
        printf("\n");
        printf("===== 2D SHAPE DRAWER =====\n");
        printf("1. Square\n");
        printf("2. Rectangle\n");
        printf("3. Triangle\n");
        printf("4. Inverted Triangle\n");
        printf("5. Diamond\n");
        printf("6. Parallelogram\n");
        printf("7. Exit\n");

        printf("Enter choice: ");
        scanf("%d",&choice);

        switch(choice)
        {
            case 1:
                square();
                break;

            case 2:
                rectangle();
                break;

            case 3:
                triangle();
                break;

            case 4:
                invertedTriangle();
                break;

            case 5:
                diamond();
                break;

            case 6:
                parallelogram();
                break;

            case 7:
                printf("Program Ended.\n");
                return 0;

            default:
                printf("Invalid Choice\n");
        }
    }

    return 0;
}
